# ── B站用户 UID（必填）──────────────────────────────────────
# 目标用户的 UID，可在 B站用户主页 URL 中找到
# 例如 https://space.bilibili.com/12345678 中的 12345678
BILIBILI_UID=

# ── 关键词过滤（选填）─────────────────────────────────────
# 只保存包含该关键词的文章；留空则抓取用户的所有文章
BILIBILI_KEYWORD=

# ── B站 Cookie（强烈推荐）─────────────────────────────────
# 设置后可大幅降低被风控的概率
#
# 获取方法：
#   1. 用 Chrome 打开 https://www.bilibili.com 并登录
#   2. F12 打开 DevTools → Network 面板
#   3. 刷新页面，点任意一个请求
#   4. 在 Request Headers 中找到 Cookie 字段，完整复制
#   5. 粘贴到下面（一整行，不要换行）
BILIBILI_COOKIE=
